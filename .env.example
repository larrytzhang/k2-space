# ─────────────────────────────────────────────────────────────
# Procedure AI — environment variables
# Copy this file to `.env` (or set these in Vercel) before running.
# ─────────────────────────────────────────────────────────────

# Required for the custom-upload flow. Samples work without this.
# Get a key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: maximum upload size in bytes (default 10 MB = 10485760).
# MAX_FILE_SIZE_BYTES=10485760
